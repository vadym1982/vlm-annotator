VLM=qwen3-vl:4b
LLM=gemma3:1b
SHOW_BOXES=1

# VERBOSE=1 for detailed logs and 0 for just a progress
VERBOSE=1

# The number by which to divide the box coordinates to get relative coordinates from 0 to 1.
# For Qwen3-vl models SCALE=1000. Leave this value empty to normalize by image size for Qwen2.5vl.
SCALE=1000

# Maximum image size in megapixels. If the image size is larger, it will be resized before detection.
MP_LIMIT=0.92

# NMS threshold for SAHI
NMS_THRESHOLD=0.5

# SAHI patches horizontal and vertical overlap
OVERLAP_W=0.2
OVERLAP_H=0.2
